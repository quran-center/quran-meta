{
  "name": "quran-meta",
  "version": "6.1.1-4",
  "description": "Library with meta data and functionality related to Holy Quran",
  "keywords": [
    "juz",
    "koran",
    "metadata",
    "quran",
    "surah"
  ],
  "homepage": "https://quran-center.github.io/quran-meta/",
  "license": "MIT",
  "author": "Huseyn Guliyev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quran-center/quran-meta.git"
  },
  "files": [
    "dist/",
    "lib_cjs/",
    "lib_es/",
    "src/",
    "types/"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/index.js",
  "jsdelivr": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./lib_cjs/index.cjs"
    },
    "./package.json": "./package.json",
    "./i18n": {
      "types": "./dist/i18n/index.d.ts",
      "import": "./dist/i18n/index.js"
    },
    "./hafs": {
      "types": "./dist/hafs.d.ts",
      "import": "./dist/hafs.js"
    },
    "./warsh": {
      "types": "./dist/warsh.d.ts",
      "import": "./dist/warsh.js"
    },
    "./qalun": {
      "types": "./dist/qalun.d.ts",
      "import": "./dist/qalun.js"
    },
    "./bazzi": {
      "types": "./dist/bazzi.d.ts",
      "import": "./dist/bazzi.js"
    },
    "./douri": {
      "types": "./dist/douri.d.ts",
      "import": "./dist/douri.js"
    },
    "./qunbul": {
      "types": "./dist/qunbul.d.ts",
      "import": "./dist/qunbul.js"
    },
    "./shuba": {
      "types": "./dist/shuba.d.ts",
      "import": "./dist/shuba.js"
    },
    "./sousi": {
      "types": "./dist/sousi.d.ts",
      "import": "./dist/sousi.js"
    }
  },
  "scripts": {
    "dev": "vitest",
    "fmt": "oxfmt .",
    "lint": "oxlint --type-aware --fix .",
    "lint:es": "eslint --fix .",
    "coverage": "vitest run --coverage",
    "docs:local": "pnpx http-server docs",
    "build": "tsdown",
    "unbuild": "pnpx unbuild --config unbuild.config.ts",
    "obuild": "pnpx obuild",
    "precommit": "pnpm lint&&pnpm build&& vitest --run",
    "prepack": "pnpm build && pnpm test:full&&pnpm tsdoc",
    "release:rc": "changelogen --release --prerelease --publish --publishTag rc",
    "release": "changelogen --release --push --publish",
    "release:gh": "changelogen gh release",
    "test": "vitest --run",
    "test:dev": "vitest",
    "test:full": "pnpm lint && pnpm test:types && pnpm coverage",
    "test:types": "tsc --noEmit",
    "tsdoc": "rimraf docs&&typedoc --hideGenerator --plugin typedoc-github-theme",
    "up": "pnpm update -i -L",
    "verify": "pnpx jiti examples/data-check/",
    "verify:lists": "pnpx jiti examples/data-check/generate-riwayah-lists.ts all --check"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.1.1",
    "@vitest/coverage-v8": "4.1.10",
    "changelogen": "^0.6.2",
    "eslint": "10.7.0",
    "eslint-plugin-tsdoc": "^0.5.2",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.24.0",
    "rimraf": "^6.1.3",
    "tsdown": "0.22.8",
    "typedoc": "^0.28.20",
    "typedoc-github-theme": "^0.4.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "pnpm@10.29.3+sha512.498e1fb4cca5aa06c1dcf2611e6fafc50972ffe7189998c409e90de74566444298ffe43e6cd2acdc775ba1aa7cc5e092a8b7054c811ba8c5770f84693d33d2dc",
  "bazzi": "./dist/bazzi.js",
  "douri": "./dist/douri.js",
  "hafs": "./dist/hafs.js",
  "i18n": "./dist/i18n/index.js",
  "iife": "./dist/index.iife.js",
  "qalun": "./dist/qalun.js",
  "qunbul": "./dist/qunbul.js",
  "shuba": "./dist/shuba.js",
  "sousi": "./dist/sousi.js",
  "warsh": "./dist/warsh.js"
}
